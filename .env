# Der Backend-Server (also der Server, der die API bereitstellt)
REACT_APP_API_SERVER_URL=https://hacilar-projekt-server.onrender.com
# REACT_APP_API_SERVER_URL=http://localhost:3355

# Starten des Servers im Developer-Mode mit HTTPS
HTTPS=false
SSL_CRT_FILE=cert/public.crt
SSL_KEY_FILE=cert/private.key
REACT_APP_REAL_FETCH=true
REACT_APP_NODE_ENV=development

# Frontend-Server (also der Server, der die React-App bereitstellt)
# ist natürlich auch über `window.document.location.origin``
# in der React-App verfügbar, wir setzen es hier für Tests.
# Daher steht hier auch kein REACT_APP davor: D.h. im normalen
# Betrieb wird diese Variable nicht gesetzt.
FRONTEND_SERVER_URL=http://localhost:3001